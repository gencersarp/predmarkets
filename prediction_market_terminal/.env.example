# ============================================================
# Prediction Market Terminal — Environment Configuration
# Copy this file to .env and fill in your credentials.
# Run `pmt check` to validate before starting.
# NEVER commit .env to version control.
# ============================================================

# ---- Runtime Mode ------------------------------------------
# paper = log orders only, no real execution (SAFE DEFAULT)
# live  = real money execution (requires all credentials below)
PMT_MODE=paper

# ---- Database ----------------------------------------------
# SQLite (default, zero config) or async PostgreSQL for production:
#   postgresql+asyncpg://user:password@localhost:5432/pmt
DATABASE_URL=sqlite+aiosqlite:///./pmt_local.db

# ---- Polymarket (CLOB + CTF) --------------------------------
# REQUIRED for live trading.
#
# How to get credentials:
#   1. Go to https://polymarket.com and connect your wallet (MetaMask recommended)
#   2. POLYMARKET_PRIVATE_KEY: Export your wallet private key (64-char hex)
#      MetaMask: Account → ... → Account Details → Export Private Key
#   3. API credentials: Polymarket → Profile → API Keys → Create API Key
#      Provides: api_key, api_secret, api_passphrase
#
POLYGON_RPC_URL=https://polygon-rpc.com
# For high-volume / live: use Alchemy (https://alchemy.com) or Infura (https://infura.io)
# both have free tiers — create an app for "Polygon Mainnet" to get a dedicated RPC URL.

POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_CLOB_ENDPOINT=https://clob.polymarket.com
POLYMARKET_GAMMA_ENDPOINT=https://gamma-api.polymarket.com
CTF_EXCHANGE_ADDRESS=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E

# ---- Kalshi ---------------------------------------------------
# REQUIRED for live Kalshi trading.
#
# How to get credentials:
#   Demo: https://kalshi.com/sign-up → practice account, no real money
#   Live: https://kalshi.com → complete ID verification
#
#   Auth method A (email+password):
#     KALSHI_API_KEY=your@email.com
#     KALSHI_API_SECRET=yourpassword
#
#   Auth method B (RSA key pair — recommended for production):
#     1. openssl genrsa -out kalshi_private.pem 2048
#     2. openssl rsa -in kalshi_private.pem -pubout -out kalshi_public.pem
#     3. Upload kalshi_public.pem at Kalshi → Account → API → Add Key
#     4. Copy the Key ID shown → set KALSHI_API_KEY=<Key ID>
#     5. Set KALSHI_PRIVATE_KEY to the full PEM content (one line, \n for newlines)
#
KALSHI_ENV=demo
KALSHI_API_KEY=
KALSHI_API_SECRET=
# KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# ---- AWS Secrets Manager (production only) ------------------
USE_AWS_SECRETS=false
AWS_REGION=us-east-1
AWS_SECRET_NAME_POLYMARKET=pmt/prod/polymarket
AWS_SECRET_NAME_KALSHI=pmt/prod/kalshi

# ---- Oracle / Fundamental Data APIs -------------------------
# All optional — system runs without them but signals will be weaker.
#
# NewsAPI — free tier: 100 requests/day, developer tier is free
#   Register at: https://newsapi.org/register
NEWSAPI_KEY=

# FRED (Federal Reserve Economic Data) — completely free, no credit card
#   Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Twitter/X Bearer Token — real-time event detection (e.g. political tweets)
#   Register at: https://developer.twitter.com/en/portal/projects-and-apps
#   Free Essential tier: 500k tweets/month read access
TWITTER_BEARER_TOKEN=

# Sports API — for sports market probability signals
#   Option A (soccer/NFL): https://rapidapi.com/api-sports/api/api-football (free 100 req/day)
#   Option B (betting odds): https://the-odds-api.com (free 500 req/month)
SPORTS_API_KEY=

# ---- Risk Parameters ----------------------------------------
MAX_PORTFOLIO_EXPOSURE_USD=1000.0
MAX_SINGLE_POSITION_USD=150.0
KELLY_FRACTION=0.25
MAX_DRAWDOWN_PCT=0.20
MAX_CORRELATION_EXPOSURE=0.40
AROC_MINIMUM_ANNUAL=0.30
FEE_EDGE_MAX_CONSUMPTION=0.40

# ---- Execution ----------------------------------------------
DEFAULT_ORDER_TYPE=IOC
SLIPPAGE_TOLERANCE_PCT=0.03
GAS_PRICE_GWEI_MAX=100

# ---- Paper Trading ------------------------------------------
PAPER_INITIAL_BALANCE_USD=1000.0

# ---- Observability ------------------------------------------
LOG_LEVEL=INFO
PROMETHEUS_PORT=9090
# SENTRY_DSN=https://...@sentry.io/...
